# Files and directories that should never be sent to the Docker build daemon.
# Keeping the build context lean speeds up `docker build` and prevents
# accidentally baking secrets or development artifacts into the image.

# Version control
.git/
.gitattributes

# Python runtime artifacts
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test suite (not needed in the production image)
tests/
.pytest_cache/
.coverage
htmlcov/

# Editor / OS noise
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Secrets — should never enter the image
.env

# Local development docs
Journal/

# Launcher scripts
airi-launcher.js

# Airi LLM Router — environment variables
# Copy this file to .env and fill in the values before starting the stack.
#
#   cp .env.example .env
#

# ─── Gateway ──────────────────────────────────────────────────────────────────

# Host port exposed by the router container.
ROUTER_PORT=8000

# ─── Upstream LLM (defaults to the Ollama service in docker-compose.yml) ─────

# Base URL of the OpenAI-compatible upstream.
# When running via docker compose, keep this pointing at the ollama service.
# For a cloud provider (OpenAI, Groq, etc.) replace with the remote URL.
LLM_BASE_URL=http://host.docker.internal:11434/v1

# API key sent in the Authorization: Bearer header.
LLM_API_KEY=ollama

# Default model name used when the request omits the `model` field.
LLM_DEFAULT_MODEL=qwen2.5:7b

# ─── Queue & concurrency ──────────────────────────────────────────────────────

# Maximum number of requests the in-memory queue will hold before returning 429.
QUEUE_MAX_SIZE=64

# Number of background worker coroutines consuming the queue concurrently.
# This hard-caps the number of simultaneous upstream inference sessions.
QUEUE_WORKER_COUNT=4

# ─── Retry policy ─────────────────────────────────────────────────────────────

# Number of retry attempts on transient upstream errors (502/503/504/429).
UPSTREAM_MAX_RETRIES=3

# ─── VRAM warmup ─────────────────────────────────────────────────────────────

# Set to false to skip the startup probe (useful in CI or CPU-only environments).
WARMUP_ENABLED=true

# ─── Multi-provider routing ───────────────────────────────────────────────────

# Default adapter when no prefix or route rule matches the model name.
# Supported values: ollama, modelscope
DEFAULT_ADAPTER=ollama

# JSON map of model-name substrings to adapter names, evaluated in order.
# CAUTION: Substring matching is greedy. A rule like "qwen" will match ALL
# qwen models (including local Ollama ones like qwen2.5:7b).
# Prefer explicit prefixes (e.g. "ms:qwen-vl-plus") over broad substring rules.
# Example: MODEL_ROUTES='{"gpt": "openai"}'
MODEL_ROUTES={}

# ─── ModelScope / DashScope ───────────────────────────────────────────────────

# Your DashScope API key (https://dashscope.aliyuncs.com).
# Leave blank if you are not using ModelScope.
MODELSCOPE_API_KEY=

# ─── Ollama ───────────────────────────────────────────────────────────────────

# Host port exposed by the Ollama container (for direct access / debugging).
OLLAMA_PORT=11434

# Set to true to suppress <think> tags in Ollama responses.
OLLAMA_DISABLE_THINK=false

# ─── GPU VRAM monitoring & circuit breaker ─────────────────────────────────

# Set to false to disable GPU monitoring entirely (falls back to static queue).
VRAM_MONITOR_ENABLED=true

# Which GPU to monitor (0-indexed). For multi-GPU rigs, pick the inference card.
VRAM_GPU_INDEX=0

# Probe frequency in seconds. Lower = more responsive, higher = less CPU overhead.
VRAM_POLL_INTERVAL=1.0

# Three-zone thresholds (percentage of total VRAM):
#   < warning  → SAFE:    full throughput, all requests accepted.
#   < danger   → WARNING: advisory headers injected; soft throttle.
#   ≥ danger   → DANGER:  hard 429 rejection, Retry-After header sent.
VRAM_THRESHOLD_WARNING=75.0
VRAM_THRESHOLD_DANGER=85.0

# Consecutive NVML read failures before falling back to static mode.
VRAM_MAX_PROBE_FAILURES=3

# Jittered Retry-After range (seconds) for 429 responses in DANGER zone.
VRAM_RETRY_AFTER_MIN=2
VRAM_RETRY_AFTER_MAX=5

# ─── Request Classification & Dispatch ───────────────────────────────────────

# Requests exceeding these thresholds are sent to the slow batch_queue.
# This prevents heavy generations from blocking fast lightweight requests.
CLASSIFIER_HEAVY_MAX_TOKENS=1024
CLASSIFIER_HEAVY_PROMPT_CHARS=2048

# ─── Image offloading ─────────────────────────────────────────────────────────

# Set to false to keep Base64 images in RAM (not recommended under high load).
IMAGE_OFFLOAD_ENABLED=true
